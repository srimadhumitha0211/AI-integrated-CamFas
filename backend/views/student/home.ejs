<!DOCTYPE html>
<html>
<head>
    <title>Student Dashboard</title>
    <link rel="stylesheet" href="glady.css">
</head>
<style>
    *{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
min-height:100vh;
background:linear-gradient(135deg,#e6c7ff,#f3dcff,#ffd6ff);
color:#333;
}


/* ================= HEADER ================= */
header{
background: rgba(203, 103, 199, 0.674);
backdrop-filter: blur(12px);
border-bottom: 1px solid rgba(255, 255, 255, 0.25);
padding:14px 0;   /* reduced */
}
.header-flex {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
 .logo-box {
        display: flex;
        align-items: center;
        gap: 12px;
    }

.logo-box img{
width:45px;
height:45px;
border-radius:50%;

border:2px solid #fff;
}

.logo-text h1{
font-size:20px;
color:#330e43;
display: flex;

}

.logo-text span{
font-size:20px;
color:#330e43;
}
.logo-text span {
        font-size: 12px;
        /* color: #f1f1f1; */
        color: #330e43;
    }
.welcome-dashboard{
width:100%;
display:flex;
justify-content:center;
margin-top:80px;
margin-bottom: 5px;
}

.welcome-dashboard h2{
text-align:center;
color:#4B0082;
font-size:28px;
}
/* ================= TOP NAV ================= */

.nav-buttons{
display:flex;
gap:18px;
text-decoration: none;
}

.nav-btn{
text-decoration: none;
        color: #330e43;
        font-size: 14px;
        /* padding: 6px 14px; */
        border-radius: 20px;
        transition: 0.3s;
       
        margin-right: 50px;
        font-size: 18px;
        font-weight: 500px;
        
}

.nav-btn:hover{
     background: rgba(255, 255, 255, 0.25);

}


/* ================= SIDEBAR NAV ================= */

.sidebar-nav{
display:flex;
justify-content:center;
gap:20px;
margin:55px 0;
flex-wrap:wrap;
}

.sidebar-nav .nav-link{
text-decoration:none;
padding:10px 18px;
border-radius:25px;
background:rgba(203, 103, 199, 0.674);
backdrop-filter:blur(10px);
font-weight:500;
color: white;
transition:0.5s;
 cursor: pointer;
}

.sidebar-nav .nav-link:hover{
background:rgb(203, 103, 200);
color:white;

}


/* ================= DASHBOARD ================= */



.dashboard-content{
max-width:1100px;
margin:20px auto;
padding:20px;
background:rgba(255,255,255,0.35);
backdrop-filter:blur(12px);
border-radius:20px;
box-shadow:0 10px 25px rgba(0,0,0,0.1);
}

.dashboard-content h2{
margin-bottom:10px;
color:#4B0082;
}


/* ===== REVIEW SECTION LAYOUT ===== */

.reviews-layout{
display:flex;
align-items:flex-start;
justify-content:center;
gap:40px;
max-width:1200px;
margin:10px auto;
padding:20px;
}

/* LEFT SIDE CONTENT */

.reviews-content{
flex:2;
}

/* RIGHT SIDE IMAGE */

.reviews-image{
flex:1;
display:flex;
justify-content:center;
}

.reviews-image img{
max-width:800px;
width:450px;
height:auto;
border-radius:10px;
box-shadow:0 8px 20px rgba(0,0,0,0.1);
margin-left: 50px;
}

/* TITLE ALIGNMENT */

.reviews-content h2{
margin-bottom:20px;
color:#4B0082;
}

/* ===== RESPONSIVE DESIGN ===== */

@media (max-width:900px){

.reviews-layout{
flex-direction:column;
align-items:center;
text-align:center;
}

.reviews-image img{
max-width:220px;
margin-top:20px;
}

}

/* ================= STATS CARDS ================= */

.stats-cards{
  margin-top: 40px;
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
margin-top:30px;
}

.stat-card{
background:rgba(255,255,255,0.6);
padding:18px;
border-radius:15px;
text-align:center;
box-shadow:0 6px 15px rgba(0,0,0,0.1);
transition:0.25s;
}

.stat-card:hover{
transform:translateY(-5px);
}

.stat-card h3{
font-size:26px;
color:#4B0082;
}

.stat-card p{
font-size:14px;
margin-top:5px;
}
.container header-flex{
    margin-bottom: 60px;
}

/* ================= FORMS ================= */

.form-row{
display:flex;
gap:20px;
flex-wrap:wrap;
}

.form-group{
flex:1;
min-width:220px;
margin-bottom:15px;
}

label{
display:block;
margin-bottom:6px;
font-weight:600;
color: rgba(203, 103, 199, 0.674);
}

input,select,textarea{
width:100%;
padding:10px;
border-radius:8px;
border:1px solid #ccc;
outline:none;
}

input:focus,
select:focus,
textarea:focus{
border-color:#8e24aa;
}


/* ================= TABLE ================= */

.table-container{
overflow-x:auto;
margin-top:20px;
}

table{
width:100%;
border-collapse:collapse;
background:white;
border-radius:10px;
overflow:hidden;
}

th{
background:linear-gradient(90deg,#8e24aa,#ba68c8);
color:white;
padding:12px;
}

td{
padding:12px;
text-align:center;
border-bottom:1px solid #eee;
}

tr:hover{
background:#f6ecff;
}


/* ================= REVIEW SECTION ================= */

.reviews-section{
/* margin-top:30px; */
max-width:1000px;
margin:30px auto;
text-align: center;
padding: 20px;
}

.review-card{
background:rgba(239, 187, 233, 0.737);
padding:20px;
border-radius:14px;
margin-bottom:15px;
box-shadow:0 4px 10px rgba(0,0,0,0.08);
transition: 0.25s;
}
.review-card:hover{
transform:translateY(-3px);
}

.review-header{
display:flex;
justify-content:space-between;
font-weight:600;
margin-bottom:6px;
}
.reviews-section h2{
text-align:center;
}

.review-meta{
font-size:13px;
color:#dd88cd;
margin-bottom:8px;
}

.review-content{
line-height:1.6;
margin-bottom:8px;
}

.skill-tag{
background:#f2e6ff;
padding:4px 10px;
border-radius:10px;
font-size:12px;
margin-right:5px;
}

#allReviewsContainer,
#myReviewsContainer{
max-width:900px;
margin:20px auto;
text-align:left;   /* keeps text readable inside cards */
}


/* ================= REVIEW FORM ================= */

.review-form{
background:rgba(255,255,255,0.5);
  /* background: rgba(203, 103, 199, 1.0);
            color: white; */
padding:20px;
border-radius:15px;
max-width: 700px;
margin: auto;
text-align: left;
}

#all-reviews div{
display:flex;
justify-content:center;
gap:10px;
flex-wrap:wrap;
}


.reviews-header{
display:flex;
align-items:center;
justify-content:center;
gap:25px;
flex-wrap:wrap;
margin-bottom:20px;
}

.review-illustration{
width:120px;
opacity:0.9;
}
/* ================= TABS ================= */

.tab-buttons{
display:flex;
gap:10px;
margin-bottom:20px;
flex-wrap:wrap;
justify-content: center;
}

.tab-btn{
padding:8px 16px;
border:none;
border-radius:20px;
 background: rgba(203, 103, 200, 0.933);
/* background:#ddd; */
cursor:pointer;
font-weight:600;
}

/* .tab-btn.active{
  background: rgba(203, 103, 199, 1.0);
            color: white;
} */


/* ================= BUTTONS ================= */

button{
cursor:pointer;
transition:0.2s;
margin-top: 10px;
  background: rgba(203, 103, 199, 1.0);
            color: white;

}

button:hover{
opacity:0.9;
  background: rgba(203, 103, 200, 0.582);
            color: white;
}


#searchCompany{
padding:10px;
width:260px;
border:1px solid #ddd;
border-radius:8px;
}

#all-reviews button{
padding:10px 16px;
border:none;
border-radius:8px;
}

/* ================= RESPONSIVE ================= */

@media(max-width:768px){

 .header-flex {
        flex-direction: column;
        gap: 15px;
         align-items: center;
        text-align: center;
    }

    .nav-buttons {
        flex-wrap: wrap;
    }
}
</style>

<body>
    
     <header>
        <div class="container header-flex" style="margin-bottom: 10px; margin-top: 10px;">

            <!-- LOGO + NAME -->
            <div class="logo-box" style="margin-left: 50px;">
                <img src="../cse-bg-img/logo.jpeg">
                <div class="logo-text">
                    <h1>CAMFAS</h1>
                    <p>Simplifying Campus Life for Faculty and Students</p>
                </div>
            </div>

            

            <!-- NAV -->
               <nav class="nav-buttons">
                    <a href="/staticPages/HOME-PAGE.html" class="nav-btn">Home</a>
                    <a href="/student/leave-form" class="nav-btn">Apply Leave</a>
                    <a href="/student/leave-history" class="nav-btn">History</a>
                    <a href="/auth/logout" class="nav-btn">Logout</a>
                     <!-- <a href="/student/ai-assistant" class="nav-btn">AI Study</a> -->
                </nav>
            

        </div>
    </header>
            <div>
                    <nav class="sidebar-nav">
                <a href="/staticPages/HOME-PAGE.html" class="nav-link active" data-section="home">
                    <i class="fas fa-home"></i> Return to Home
                </a>
                <a href="leave-form" class="nav-link" data-section="apply-leave">
                    <i class="fas fa-file-upload"></i> Apply for Leave
                </a>
                <a href="leave-history" class="nav-link" data-section="my-leaves">
                    <i class="fas fa-history"></i> My Leave History
                </a>
                </nav>
            </div>
            


<!-- <div class="dashboard-content"> -->
<div class="welcome-dashboard">
    <h2>Welcome, <%= user.name %>!</h2>
</div>

    



    <!-- Internship Reviews Section -->
<div class="reviews-section">

<div class="reviews-layout">

<div class="reviews-content">

<h2>💼 Internship Reviews Portal</h2>

<!-- Tab Buttons -->
<div class="tab-buttons">
    <button class="tab-btn active" onclick="showTab('all-reviews')">All Reviews</button>
    <button class="tab-btn" onclick="showTab('my-reviews')">My Reviews</button>
    <button class="tab-btn" onclick="showTab('post-review')">Post Review</button>
</div>


    
    <!-- Tab 1: All Reviews -->
    <div id="all-reviews" class="tab-content">
        <div style="margin-bottom: 15px;">
            <input type="text" id="searchCompany" placeholder="Search company..." style="padding: 8px; width: 300px; border: 1px solid #ddd; border-radius: 5px;">
            <button onclick="searchReviews()" style="padding: 8px 16px; background: rgb(203, 103, 200); color: white; border: none; border-radius: 5px;">Search</button>
        </div>
        <div id="allReviewsContainer">
            <!-- Reviews will be loaded here -->
            <p style="text-align: center; color: #7f8c8d;">Loading reviews...</p>
        </div>
    </div>
    
    <!-- Tab 2: My Reviews -->
    <div id="my-reviews" class="tab-content" style="display: none;">
        <div id="myReviewsContainer">
            <!-- My reviews will be loaded here -->
            <p style="text-align: center; color: #7f8c8d;">Loading your reviews...</p>
        </div>
    </div>
    
    <!-- Tab 3: Post Review Form -->
    <div id="post-review" class="tab-content" style="display: none;">
        <div class="review-form">
            <h3 style="margin-bottom: 20px;">✍️ Share Your Internship Experience</h3>
            
            <form action="/reviews/submit" method="POST">
                <div class="form-row">
                    <div>
                        <label>Company Name *</label>
                        <input type="text" name="companyName" required placeholder="e.g., Google, Microsoft">
                    </div>
                    <div>
                        <label>Position *</label>
                        <input type="text" name="position" required placeholder="e.g., Software Intern">
                    </div>
                </div>
                
                <div class="form-row">
                    <div>
                        <label>Internship Duration *</label>
                        <input type="text" name="internshipDuration" required placeholder="e.g., 3 months">
                    </div>
                    <div>
                        <label>Stipend (Optional)</label>
                        <input type="text" name="stipend" placeholder="e.g., ₹20,000/month">
                    </div>
                </div>
                
                <div class="form-row">
                    <div>
                        <label>Rating *</label>
                        <select name="rating" required>
                            <option value="">Select rating</option>
                            <option value="5">⭐⭐⭐⭐⭐ Excellent</option>
                            <option value="4">⭐⭐⭐⭐ Very Good</option>
                            <option value="3">⭐⭐⭐ Good</option>
                            <option value="2">⭐⭐ Fair</option>
                            <option value="1">⭐ Poor</option>
                        </select>
                    </div>
                    <div>
                        <label>Skills Learned</label>
                        <input type="text" name="skills" placeholder="e.g., React, Node.js, Python">
                    </div>
                </div>
                
                <div>
                    <label>Your Review *</label>
                    <textarea name="review" rows="2" required placeholder="Share your experience..."></textarea>
                </div>
                
                <button type="submit" >
                    📤 Submit Review
                </button>
            </form>
        </div>
    </div>
</div> 
<div class="reviews-image">
<img src="../cse-bg-img/review2.jpg" alt="Internship Illustration">
</div>

</div>
</div>


<div class="stats-cards">
        <div class="stat-card">
            <h3 id="pendingCount">0</h3>
            <p>Pending Leaves</p>
        </div>

        <div class="stat-card">
            <h3 id="approvedCount">0</h3>
            <p>Approved Leaves</p>
        </div>

        <div class="stat-card">
            <h3 id="rejectedCount">0</h3>
            <p>Rejected Leaves</p>
        </div>

        <div class="stat-card">
            <h3 id="totalCount">0</h3>
            <p>Total Applications</p>
        </div>
    </div>


    <script>
        // Fetch stats from API
        fetch('/leave/my-leaves')
            .then(res => res.json())
            .then(leaves => {
                document.getElementById('pendingCount').textContent = 
                    leaves.filter(l => l.status.includes('pending')).length;
                document.getElementById('approvedCount').textContent = 
                    leaves.filter(l => l.status === 'approved').length;
                document.getElementById('rejectedCount').textContent = 
                    leaves.filter(l => l.status === 'rejected').length;
                document.getElementById('totalCount').textContent = leaves.length;
            });

            function showTab(tabId) {
    document.querySelectorAll('.tab-content').forEach(tab => {
        tab.style.display = 'none';
    });
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.classList.remove('active');
    });
    
    document.getElementById(tabId).style.display = 'block';
    event.target.classList.add('active');
    
    // Load data based on tab
    if (tabId === 'all-reviews') loadAllReviews();
    if (tabId === 'my-reviews') loadMyReviews();
}

// Load all approved reviews
async function loadAllReviews() {
    try {
        const response = await fetch('/reviews/all');
        const reviews = await response.json();
        
        const container = document.getElementById('allReviewsContainer');
        
        if (reviews.length === 0) {
            container.innerHTML = '<p style="text-align: center; color: #7f8c8d;">No reviews yet. Be the first to share!</p>';
            return;
        }
        
        container.innerHTML = reviews.map(review => `
            <div class="review-card">
                <div class="review-header">
                    <span class="company-name">${review.companyName}</span>
                    <span class="rating">${'⭐'.repeat(review.rating)}</span>
                </div>
                <div class="review-meta">
                    <span>👤Name: ${review.studentName} | 💼Designation: ${review.position} | 📅Posted date: ${new Date(review.postedAt).toLocaleDateString()}</span>
                </div>
                <div class="review-content">
                    Review about internship:${review.review}
                </div>
                <div style="margin-top: 10px;">
                    <span class="stipend-badge">💰Stipend: ${review.stipend || 'Unpaid'}</span>
                    <span class="stipend-badge">⏱️Duration: ${review.internshipDuration}</span>
                </div>
                <div class="skills-tags">
                   Skills gained: ${review.skills ? review.skills.split(',').map(skill => 
                        `<span class="skill-tag">🔹 ${skill.trim()}</span>`
                    ).join('') : ''}
                </div>
            </div>
        `).join('');
        
    } catch (error) {
        console.error('Error loading reviews:', error);
    }
}

// Load current user's reviews
async function loadMyReviews() {
    try {
        const response = await fetch('/reviews/my-reviews');
        const reviews = await response.json();
        
        const container = document.getElementById('myReviewsContainer');
        
        if (reviews.length === 0) {
            container.innerHTML = '<p style="text-align: center; color: #7f8c8d;">You haven\'t posted any reviews yet.</p>';
            return;
        }
        
        container.innerHTML = reviews.map(review => `
            <div class="review-card" style="border-left: 4px solid ${review.isApproved ? '#28a745' : '#ffc107'}">
                <div class="review-header">
                    <span class="company-name">${review.companyName}</span>
                    <span class="rating">${'⭐'.repeat(review.rating)}</span>
                </div>
                <div class="review-meta">
                    <span>Status: ${review.isApproved ? '✅ Approved' : '⏳ Pending Approval'}</span>
                </div>
                <div class="review-content">
                    ${review.review}
                </div>
            </div>
        `).join('');
        
    } catch (error) {
        console.error('Error loading my reviews:', error);
    }
}

// Search function
function searchReviews() {
    const searchTerm = document.getElementById('searchCompany').value.toLowerCase();
    const cards = document.querySelectorAll('#allReviewsContainer .review-card');
    
    cards.forEach(card => {
        const companyName = card.querySelector('.company-name').textContent.toLowerCase();
        if (companyName.includes(searchTerm) || searchTerm === '') {
            card.style.display = 'block';
        } else {
            card.style.display = 'none';
        }
    });
}

// Initial load
loadAllReviews();

// Check URL parameter for success message
const urlParams = new URLSearchParams(window.location.search);
if (urlParams.get('review') === 'success') {
    alert('✅ Your review has been submitted successfully! It will be visible after approval.');
}
    </script>
</body>
</html>