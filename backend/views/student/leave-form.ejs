    <!-- ===== NEW: EMERGENCY LEAVE MODAL ===== -->
    <div class="modal" id="emergencyModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); justify-content:center; align-items:center; z-index:999;">
        <div class="modal-content">
            <h2 style="color:white; margin-bottom:12px;">🚨 Emergency Leave Application</h2>
            <p style="color:#ffe0f0; font-size:14px; margin-bottom:14px;">
                Couldn't apply before your leave? Submit it now — an apology message will be auto-attached and sent to your faculty.
            </p>

            <div class="form-group">
                <label style="color:white;">Start Date</label>
                <input type="date" id="emergencyStart">
            </div>
            <div class="form-group">
                <label style="color:white;">End Date</label>
                <input type="date" id="emergencyEnd">
            </div>
            <div class="form-group">
                <label style="color:white;">Reason for Emergency</label>
                <input type="text" id="emergencyReason" placeholder="e.g. Family medical emergency">
            </div>

            <div style="background:rgba(255,255,255,0.15); border-radius:10px; padding:12px; margin-bottom:14px;">
                <p style="color:#ffe0f0; font-size:13px;">
                    ⚠️ <strong>Auto-apology that will be sent:</strong><br>
                    <em>"I sincerely apologize for not applying for leave in advance due to an unavoidable emergency. I request your kind understanding."</em>
                </p>
            </div>

            <div class="form-actions">
                <button class="btn btn-primary" onclick="submitEmergencyLeave()">
                    <i class="fas fa-paper-plane"></i> Submit Emergency Leave
                </button>
                <button class="btn btn-secondary" onclick="closeEmergencyModal()">Cancel</button>
            </div>
        </div>
