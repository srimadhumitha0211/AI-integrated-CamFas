<body>
    <header style="padding: 10px; margin-bottom: 25px; border-radius:20px;">
        <div class="container header-flex">
            <div class="logo-box">
                <img src="/cse-bg-img/logo.jpeg" alt="College Logo">
                <div class="logo-text">
                    <h1>CAMFAS</h1>
                    <p>Simplifying Campus Life for Faculty and Students</p>
                </div>
            </div>
            <nav class="nav-buttons">
                <a style="text-decoration: none;" href="/student/dashboard">Home</a>
                <a style="text-decoration: none;" href="/student/leave-form">Apply Leave</a>
                <a style="text-decoration: none;" href="/student/leave-history">History</a>
                <a style="text-decoration: none;" href="/auth/logout">Logout</a>
            </nav>
        </div>
    </header>

    <!-- Apply leave section -->
    <section id="apply-leave-section" class="dashboard-section">
        <div class="section-header">
            <h2><i class="fas fa-file-upload"></i> Apply for Leave</h2>
            <!-- NEW: Emergency Leave Button -->
            <button class="btn btn-emergency" onclick="openEmergencyModal()">
                🚨 Emergency Leave
            </button>
        </div>
        <h3>Fill the form below to apply for leave</h3>

        <form id="leaveForm" class="leave-form" action="/leave/submit" method="POST">
            <div class="form-row">
                <div class="form-group">
                    <label for="leaveType"><i class="fas fa-tag"></i> Leave Type</label>
                    <select id="leaveType" name="leaveType" required>
                        <option value="">Select leave type</option>
                        <option value="personal">Personal Leave</option>
                        <option value="medical">Medical Leave</option>
                        <option value="od">OD</option>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="startDate"><i class="fas fa-calendar-alt"></i> Start Date</label>
                    <input type="date" id="startDate" name="startDate" required>
                    <label for="endDate"><i class="fas fa-calendar-alt"></i> End Date</label>
                    <input type="date" id="endDate" name="endDate" required>
                </div>
            </div>

            <div class="form-group">
                <label for="reason"><i class="fas fa-comment"></i> Reason</label>
                <textarea id="reason" name="reason" rows="1" required placeholder="Provide your reason"></textarea>
            </div>

            <!-- NEW: Optional Apology Message on Normal Form -->
            <div class="form-group" id="apologySection" style="display:none;">
                <label for="apologyMsg"><i class="fas fa-envelope"></i> Apology Message <span style="font-size:12px; color:#888;">(optional — sent to faculty along with this leave)</span></label>
                <textarea id="apologyMsg" name="apologyMessage" rows="2" placeholder="Dear Sir/Madam, I apologize for..."></textarea>
            </div>

            <div style="margin-bottom:12px;">
                <label style="font-weight:400; color:#555; display:flex; align-items:center; gap:8px; cursor:pointer;">
                    <input type="checkbox" id="includeApology" onchange="toggleApology()" style="width:auto;">
                    Include an apology message with this leave application
                </label>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-paper-plane"></i> Submit Application
                </button>
                <button type="button" class="btn btn-secondary" id="cancelLeaveBtn" onclick="window.location.href='/student/dashboard'">
                    Cancel
                </button>
            </div>
        </form>
    </section>

    <div class="dashboard-content">
        <section id="home-section" class="dashboard-section active">
            <div class="stats-cards">
                <div class="stat-card">
                    <div class="stat-info">
                        <h3 id="pendingCount">0</h3>
                        <p>Pending</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon approved">
                        <i class="fas fa-file-alt"></i>
                    </div>
                    <div class="stat-info">
                        <h3 id="approvedCount">0</h3>
