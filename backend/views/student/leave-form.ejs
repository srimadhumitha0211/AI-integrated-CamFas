    </style>

    <script>
        // Set min date to today
        const today = new Date().toISOString().split('T')[0];
        document.getElementById('startDate').min = today;
        document.getElementById('endDate').min = today;

        document.getElementById('startDate').addEventListener('change', function() {
            document.getElementById('endDate').min = this.value;
        });

        // Fetch stats for dashboard
        fetch('/leave/my-leaves')
            .then(res => res.json())
            .then(leaves => {
                document.getElementById('pendingCount').textContent = 
                    leaves.filter(l => l.status.includes('pending')).length;
                document.getElementById('approvedCount').textContent = 
                    leaves.filter(l => l.status === 'approved').length;
                document.getElementById('rejectedCount').textContent = 
                    leaves.filter(l => l.status === 'rejected').length;
                document.getElementById('totalCount').textContent = leaves.length;
            });

        // ===== NEW: Toggle apology textarea =====
        function toggleApology() {
            const checked = document.getElementById('includeApology').checked;
            document.getElementById('apologySection').style.display = checked ? 'block' : 'none';
        }

        // ===== NEW: Open / Close Emergency Modal =====
        function openEmergencyModal() {
            const modal = document.getElementById('emergencyModal');
            modal.style.display = 'flex';
        }

        function closeEmergencyModal() {
            const modal = document.getElementById('emergencyModal');
            modal.style.display = 'none';
            document.getElementById('emergencyStart').value  = '';
            document.getElementById('emergencyEnd').value    = '';
            document.getElementById('emergencyReason').value = '';
        }

        // Close modal when clicking outside the box
        document.getElementById('emergencyModal').addEventListener('click', function(e) {
            if (e.target === this) closeEmergencyModal();
        });

        // ===== NEW: Submit Emergency Leave =====
        async function submitEmergencyLeave() {
            const startDate = document.getElementById('emergencyStart').value;
            const endDate   = document.getElementById('emergencyEnd').value;
            const reason    = document.getElementById('emergencyReason').value.trim();

            if (!startDate || !endDate || !reason) {
                alert('Please fill in all fields.');
                return;
            }

            const autoApology = "I sincerely apologize for not applying for leave in advance due to an unavoidable emergency. I request your kind understanding.";

            try {
                const res = await fetch('/leave/apply', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        leaveType: 'Emergency Leave',
                        startDate,
                        endDate,
                        reason,
                        apologyMessage: autoApology,
                        status: 'emergency'
                    })
                });

                if (res.ok) {
                    closeEmergencyModal();
                    showToast('🚨 Emergency leave submitted with apology to faculty!');
                } else {
                    alert('Submission failed. Please try again.');
                }
            } catch (err) {
                alert('Something went wrong. Please try again.');
            }
        }

        // ===== NEW: Toast =====
        function showToast(msg) {
            const toast = document.getElementById('toast');
            toast.textContent = msg;
            toast.style.display = 'block';
            setTimeout(() => { toast.style.display = 'none'; }, 3500);
        }
    </script>
