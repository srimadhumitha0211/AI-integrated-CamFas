    <!-- Apply leave section -->
    <section id="apply-leave-section" class="dashboard-section">
        <div class="section-header">
            <h2><i class="fas fa-file-upload"></i> Apply for Leave</h2>
        </div>
        <h3>Fill the form below to apply for leave</h3>

        <form id="leaveForm" class="leave-form" action="/leave/submit" method="POST">
            <div class="form-row">
                <div class="form-group">
                    <label for="leaveType"><i class="fas fa-tag"></i> Leave Type</label>
                    <select id="leaveType" name="leaveType" required>
                        <option value="">Select leave type</option>
                        <option value="personal">Personal Leave</option>
                        <option value="medical">Medical Leave</option>
                        <option value="od">OD</option>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="startDate"><i class="fas fa-calendar-alt"></i> Start Date</label>
                    <input type="date" id="startDate" name="startDate" required>
               
                    <label for="endDate"><i class="fas fa-calendar-alt"></i> End Date</label>
                    <input type="date" id="endDate" name="endDate" required>
                </div>
            </div>

            <div class="form-group">
                <label for="reason"><i class="fas fa-comment"></i> Reason</label>
                <textarea id="reason" name="reason" rows="1" required placeholder="Provide your reason"></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-paper-plane"></i> Submit Application
                </button>
                <button type="button" class="btn btn-secondary" id="cancelLeaveBtn" onclick="window.location.href='/student/dashboard'">
                    Cancel
                </button>
            </div>
        </form>
    </section>

    <div class="dashboard-content">
        <!-- Home Section (simplified) -->
        <section id="home-section" class="dashboard-section active">
            <div class="stats-cards">
                <div class="stat-card">
                    <div class="stat-info">
                        <h3 id="pendingCount">0</h3>
                        <p>Pending</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon approved">
                        <i class="fas fa-file-alt"></i>
                    </div>
                    <div class="stat-info">
                        <h3 id="approvedCount">0</h3>
                        <p>Approved Leaves</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon rejected">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <div class="stat-info">
                        <h3 id="rejectedCount">0</h3>
                        <p>Rejected Leaves</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon total">
                        <i class="fas fa-times-circle"></i>
                    </div>
                    <div class="stat-info">
                        <h3 id="totalCount">0</h3>
                        <p>Total</p>
                    </div>
                </div>
            </div>
