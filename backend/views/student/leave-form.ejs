                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon rejected">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <div class="stat-info">
                        <h3 id="rejectedCount">0</h3>
                        <p>Rejected Leaves</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon total">
                        <i class="fas fa-times-circle"></i>
                    </div>
                    <div class="stat-info">
                        <h3 id="totalCount">0</h3>
                        <p>Total</p>
                    </div>
                </div>
            </div>
        </section>

        <footer class="footer-wrapper">
            <div class="wrapper-1" style="margin-left: 30px;">
                <h4>Department</h4>
                <ul>
                    <li>CSE</li>
                    <li>AI & DS</li>
                    <li>EEE</li>
                    <li>ECE</li>
                    <li>MECH</li>
                </ul>
            </div>
            <div class="wrapper-2">
                <h4>About Us</h4>
                <ul>
                    <li>Educate</li>
                    <li>Innovate</li>
                    <li>Inspire</li>
                    <li>Lead</li>
                </ul>
            </div>
            <div class="wrapper-3">
                <div>
                    <h4>Contact Us</h4>
                    <ul>
                        <li>Location: Thoothukudi, Tamil Nadu</li>
                        <li>Phone: +91 94432 01279</li>
                        <li>Email: principal@mtec.ac.in</li>
                    </ul>
                </div>
                <div class="social-links">
                    <a href="https://www.instagram.com">🅾 Instagram</a>
                    <a href="https://www.facebook.com">Facebook</a>
                    <a href="https://www.linkedin.com">LinkedIn</a>
                </div>
            </div>
            <div class="wrapper-4">
